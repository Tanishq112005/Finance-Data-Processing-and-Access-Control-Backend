{
  "name": "finacedashboard",
  "version": "1.0.0",
  "description": "Backend for Finance Data Processing and Access Control.",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "dev:api": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:email": "ts-node-dev --respawn --transpile-only src/workers/email.ts",
    "dev:finance": "ts-node-dev --respawn --transpile-only src/workers/finance.ts",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:email\" \"npm run dev:finance\"",
    "start:api": "node dist/server.js",
    "start:email": "node dist/workers/email.js",
    "start:finance": "node dist/workers/finance.js",
    "start": "concurrently \"npm run start:api\" \"npm run start:email\" \"npm run start:finance\"",
    "build": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tanishq112005/Finance-Data-Processing-and-Access-Control-Backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Tanishq112005/Finance-Data-Processing-and-Access-Control-Backend/issues"
  },
  "homepage": "https://github.com/Tanishq112005/Finance-Data-Processing-and-Access-Control-Backend#readme",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.3",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/pg": "^8.20.0",
    "amqplib": "^1.0.3",
    "bcryptjs": "^3.0.3",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
