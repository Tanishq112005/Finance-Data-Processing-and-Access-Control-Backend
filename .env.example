# Network Settings
PORT=3000

# Database Configuration (Neon DB / PostgreSQL)
# Example: postgresql://user:password@localhost:5432/finance_db?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/finance_db?schema=public

# JWT configuration
JWT_SECRET="super-secret-key-replace-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-replace-in-production"

# Redis Configuration (For OTP caching and write-behind records)
REDIS_URL=redis://localhost:6379

# Rate Limiting
MAX_ATTEMPTS=10
WINDOW_SIZE=60

# RabbitMQ Configuration (Message Broker)
RABBITMQ_URL=amqp://localhost

# Email Provider Configuration (Brevo configuration for OTPs)
BREVO_API_KEY="your_brevo_api_key_here"
BREVO_SENDER_EMAIL="your_sender_email@example.com"

# OTP Expiration Time in seconds (e.g., 300 = 5 minutes)
OTP_EXPIRE_TIME=300
